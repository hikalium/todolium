{
  "compilerOptions": {
    "module": "es2022",
    "preserveConstEnums": true,
    "outDir": "./generated/",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
